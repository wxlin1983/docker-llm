# Copy this file to .env and fill in real values. .env is gitignored and lives
# outside the Docker build context (docker/), so it is only ever injected at
# container runtime via `env_file` -- never baked into the image.

# The GitHub PAT does NOT go in this file: it lives in .secrets/github_pat (a
# Docker file secret, so it never appears in any process's environment). Set it
# up with:
#   mkdir -p .secrets && chmod 700 .secrets
#   printf '%s' 'github_pat_XXXX' > .secrets/github_pat && chmod 600 .secrets/github_pat
# (leave the file empty for no GitHub auth). Use a fine-grained PAT scoped to
# only the repo(s) you need, with an expiration date:
# https://github.com/settings/tokens?type=beta

# GitHub username associated with the PAT in .secrets/github_pat.
GITHUB_USER=

# Host path to bind-mount into the container at /workspace.
# Defaults to ./workspace if unset.
SOURCE_DIR=./workspace

# Resource caps for the sandbox container (defaults sized for a 4-core/16G host;
# leave commented to use them). memswap is pinned to the same value as the
# memory limit, so exceeding it OOM-kills the offender instead of swapping.
#SANDBOX_CPUS=3
#SANDBOX_MEM_LIMIT=6g
